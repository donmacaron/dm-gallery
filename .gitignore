# ═══════════════════════════════════════════
# Don Macaron Gallery — .gitignore
# ═══════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
analyze_refs.py
list_refs.py

# ── Virtual envs ──
venv/
env/
.venv/
ENV/

# ── Data (NEVER commit!) ──
data/
*.db
*.db-shm
*.db-wal

# ── Environment (secrets!) ──
.env
!.env.example

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Logs ──
*.log
logs/

# ── Alembic generated (keep versions but not pycache) ──
migrations/__pycache__/

# ── Temp ──
*.tmp
*.bak
*.orig

ref_analysis.json
.traefik-upload.yml