# ═══════════════════════════════════════════
#  Don Macaron Gallery — Environment Config
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Admin ──────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_please_!!
SECRET_KEY=generate_a_very_long_random_string_here_at_least_32_chars

# ── Storage ──────────────────────────────────
# Originals storage: change to any drive/folder
# Windows: ORIGINALS_PATH=D:/photos/originals
# Linux:   ORIGINALS_PATH=/mnt/external/photos
ORIGINALS_PATH=./data/originals

# Internal storage paths (usually don't change these)
MEDIA_PATH=./data/media
ZIPS_PATH=./data/zips
DB_PATH=./data/db/gallery.db

# ── App ──────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# HTTP Port exposed by nginx
HTTP_PORT=80

# ── Site ──────────────────────────────────────
SITE_TITLE=Don Macaron Gallery
SITE_TAGLINE=Photography
